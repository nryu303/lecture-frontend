# Environment-based Configuration
NODE_ENV=production

# Development Configuration (when NODE_ENV=development)
DEV_FRONTEND_URL=http://localhost:5173
DEV_API_URL=http://localhost:4000

# API URL used by the frontend (only VITE_-prefixed vars reach the client).
# Set to the local dev backend; comment out / remove to fall back to production.
VITE_API_URL=http://localhost:4000

# Production Configuration (when NODE_ENV=production)
PROD_FRONTEND_URL=lecture-backend-production-7d75.up.railway.app:5173
PROD_API_URL=lecture-backend-production-7d75.up.railway.app

# Stripe Public Key

# Face Check Duration
VITE_FACE_CHECK_DURATION=900